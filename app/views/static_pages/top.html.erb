<section class="space-y-4 pt-6 max-w-5xl mx-auto px-4">
  <div class="overflow-hidden rounded-xl shadow-md">
    <% if @top_hero_images.any? %>
      <% @top_hero_images.each do |page_image| %>
        <%= image_tag page_image.image.url,
            class: "w-full h-[240px] sm:h-[340px] object-cover" %>
      <% end %>
    <% else %>
      <%= image_tag "HIGASHIYAMA_FARM.png",
          class: "w-full h-[240px] sm:h-[340px] object-cover" %>
    <% end %>
  </div>

  <div class="text-center px-4">
    <h1 class="text-2xl sm:text-3xl font-bold text-green-700">
      HIGASHIYAMA FARM
    </h1>
    <p class="mt-2 text-gray-700">
      家族や友人と楽しめる、さつまいも収穫体験
    </p>
    <p class="text-sm text-gray-700 mt-1">
      📍 千葉県柏市の農園で開催しています
    </p>
  </div>
</section>

<div class="max-w-2xl mx-auto px-4 py-10 space-y-10">

  <!-- 営業日 -->
  <%= render "shared/business_calendar",
    events: @events,
    title: "営業日カレンダー",
    note: "※開催は1日2回（10:00 / 13:00）です",
    min_reservable_date: @min_reservable_date,
    max_reservable_date: @max_reservable_date %>

  <!-- 次にすること -->
  <section class="bg-white rounded-lg shadow-md p-6 border border-orange-100 space-y-4">

    <div class="grid gap-3 pt-2">
      <%= link_to "はじめての方はこちら（使い方）", guide_path,
          class: "w-full sm:max-w-sm sm:mx-auto block text-center px-4 py-3 font-bold rounded bg-orange-100 text-orange-800 hover:bg-orange-200 transition" %>

      <%= link_to "ご予約はこちら", new_reservation_path,
          class: "w-full sm:max-w-sm sm:mx-auto block text-center px-4 py-3 font-bold rounded bg-orange-500 text-white hover:bg-orange-600 shadow-sm transition" %>

      <%= link_to "ご予約の確認はこちら", search_reservations_path,
          class: "w-full sm:max-w-sm sm:mx-auto block text-center px-4 py-3 font-bold rounded border-2 border-orange-300 bg-white text-orange-700 hover:bg-orange-50 transition" %>
    </div>

    <div class="pt-4 border-t">
      <%= link_to "農園関係者の方はこちら", admin_login_path,
          class: "w-full sm:max-w-sm sm:mx-auto block text-center px-4 py-3 font-bold rounded bg-gray-100 text-gray-800 hover:bg-gray-200 transition" %>
    </div>
  </section>

  <!-- アクセス -->
  <section class="space-y-4">
    <h2 class="text-center">
      <span class="inline-block rounded bg-orange-100 px-6 py-2 text-xl font-bold text-gray-800">
        アクセス
      </span>
    </h2>

    <div class="bg-white rounded-lg shadow-md p-6 border border-orange-100 space-y-3">
      <div class="text-center text-gray-700 space-y-1">
        <p>📍 西山パークサイド駐車場が目印です。</p>
        <p>🚗 駐車場は西山パークサイド駐車場に1台分あります。</p>
      </div>

      <div class="rounded-lg overflow-hidden border border-gray-200">
        <iframe
          src="https://www.google.com/maps?q=35.823528,139.951944&z=15&output=embed"
          width="100%"
          height="360"
          style="border:0;"
          allowfullscreen=""
          loading="lazy">
        </iframe>
      </div>
    </div>
  </section>

</div>