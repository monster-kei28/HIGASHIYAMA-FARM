<div class="max-w-4xl mx-auto px-4 py-8 space-y-6">
  <div class="text-center space-y-1">
    <h2 class="text-xl font-bold text-green-700">予約一覧（管理者）</h2>
    <p class="text-xs text-gray-600">予約の確認・削除ができます</p>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-orange-100 p-4 space-y-4">
    <div class="flex items-center justify-between text-xs text-gray-600">
      <span>
        件数：
        <span class="font-bold text-gray-800"><%= @reservations.size %></span>
      </span>

      <%= link_to "CSV出力",
          admin_reservations_path(format: :csv),
          class: "px-3 py-1 text-xs font-bold text-white bg-green-600 rounded hover:bg-green-700" %>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-xs">
        <thead class="bg-orange-50">
          <tr>
            <th class="border px-2 py-2 text-left">名前</th>
            <th class="border px-2 py-2 text-left">電話</th>
            <th class="border px-2 py-2 text-left">体験</th>
            <th class="border px-2 py-2 text-right">人数</th>
            <th class="border px-2 py-2 text-left">日時</th>
            <th class="border px-2 py-2 text-center">操作</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% @reservations.each do |r| %>
            <tr class="hover:bg-orange-50/40">
              <td class="border px-2 py-2"><%= r.user.name %></td>
              <td class="border px-2 py-2"><%= r.user.phone_number %></td>
              <td class="border px-2 py-2"><%= r.harvest_experience.title %></td>
              <td class="border px-2 py-2 text-right"><%= r.number_of_people %></td>
              <td class="border px-2 py-2">
                <%= r.reserved_at&.strftime("%Y/%m/%d %H:%M") %>
              </td>
              <td class="border px-2 py-2">
                <div class="flex items-center justify-center gap-2">
                  <%= link_to "詳細",
                      admin_reservation_path(r),
                      class: "px-2 py-1 text-blue-700 border border-blue-200 rounded hover:bg-blue-50 font-bold text-xs" %>

                  <%= link_to "削除",
                      admin_reservation_path(r),
                      data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                      class: "px-2 py-1 text-red-600 border border-red-200 rounded hover:bg-red-50 font-bold text-xs" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @reservations.empty? %>
      <div class="text-center text-xs text-gray-600 py-4">
        予約はまだありません。
      </div>
    <% end %>
  </div>
</div>

<div class="text-center mt-6">
  <%= link_to "管理者トップへ戻る",
      admin_root_path,
      class: "inline-flex items-center justify-center rounded-md bg-gray-200 px-5 py-2 text-sm font-bold text-gray-700 border hover:bg-gray-300 transition" %>
</div>
