<div class="max-w-md mx-auto px-4 py-10">
  <div class="bg-white rounded-lg shadow-md p-6 border border-orange-100 space-y-5">
    <h1 class="text-xl font-bold text-green-700 text-center">管理者を追加</h1>

    <% if @admin.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4 text-sm text-red-700">
        <ul class="list-disc ml-5 space-y-1">
          <% @admin.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: [:admin, @admin] do |f| %>
      <div class="space-y-2">
        <%= f.label :uid, "追加する管理者のLINE UID", class: "text-sm font-bold text-gray-700" %>

        <%= f.text_field :uid,
              class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-200 font-mono",
              placeholder: "Ucxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
              autocapitalize: "off",
              autocomplete: "off",
              spellcheck: false %>

        <p class="text-xs text-gray-500 leading-relaxed">
          ※ 追加したい人に <strong>先にLINEログイン</strong>してもらう必要があります。<br>
          （ログイン済みのユーザーを検索して、管理者に紐付けるため。名前も表示できます）
        </p>
      </div>

      <div class="pt-4 space-y-3">
        <%= f.submit "追加する",
              class: "w-full rounded-md bg-green-600 px-4 py-3 font-bold text-white shadow hover:bg-green-700 transition" %>

        <%= link_to "戻る", admin_admins_path,
              class: "block w-full text-center rounded-md bg-white px-4 py-3 font-bold text-gray-700 border border-gray-200 hover:bg-gray-50 transition" %>
      </div>
    <% end %>
  </div>
</div>