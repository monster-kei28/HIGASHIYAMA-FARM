<div class="max-w-4xl mx-auto px-4 py-10 space-y-6">

  <div class="bg-white rounded-lg shadow-md border border-orange-100 p-6 space-y-4">
    <div class="text-center space-y-1">
      <h1 class="text-2xl font-bold text-green-700">管理者一覧</h1>
      <p class="text-sm text-gray-600">
        現在の管理者:
        <span class="font-bold text-gray-800"><%= @current_admin&.user&.name.presence || "（未入力）" %></span>
      </p>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2">
      <%= link_to "LINEログイン済みユーザーを管理者に追加",
                  admin_users_path,
                  class: "w-full sm:w-auto inline-flex items-center justify-center rounded-md bg-green-600 px-4 py-2 font-bold text-white shadow hover:bg-green-700 transition" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-orange-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-[860px] w-full text-sm">
        <thead class="bg-orange-50">
          <tr>
            <th class="text-left px-4 py-3">名前</th>
            <th class="text-left px-4 py-3">追加日</th>
            <th class="px-4 py-3 text-right">操作</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% @admins.each do |admin| %>
            <tr class="hover:bg-orange-50/40">
              <td class="px-4 py-3 text-gray-800">
                <div class="flex items-center gap-2">
                  <span class="font-bold">
                    <%= admin.user&.name.presence || "（未ログイン）" %>
                  </span>

                  <% if admin.uid == session[:admin_uid] %>
                    <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                      あなた
                    </span>
                  <% end %>
                </div>
              </td>

              <td class="px-4 py-3 text-gray-600 whitespace-nowrap">
                <%= l(admin.created_at, format: :short) rescue admin.created_at %>
              </td>

              <td class="px-4 py-3 text-right whitespace-nowrap">
                <%= button_to "削除",
                              admin_admin_path(admin),
                              method: :delete,
                              data: { turbo_confirm: "この管理者を削除しますか？" },
                              class: "inline-flex items-center justify-center rounded-md bg-white px-3 py-1.5 font-bold text-red-600 border border-red-200 hover:bg-red-50 transition" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @admins.empty? %>
      <div class="text-center text-sm text-gray-600 py-8">
        管理者がまだ登録されていません。
      </div>
    <% end %>
  </div>

  <div class="text-center">
    <%= link_to "管理者トップへ戻る",
                admin_root_path,
                class: "inline-flex items-center justify-center rounded-md bg-gray-200 px-6 py-2 font-bold text-gray-700 border hover:bg-gray-300 transition" %>
  </div>

</div>
