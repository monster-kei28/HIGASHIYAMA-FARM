<div class="max-w-3xl mx-auto px-4 py-10 space-y-6">
  <div class="bg-white rounded-lg shadow-md p-6 border border-orange-100 space-y-2">
    <h1 class="text-xl font-bold text-green-700 text-center">管理者一覧</h1>
    <p class="text-sm text-gray-600 text-center">
      現在の管理者UID: <span class="font-mono text-gray-800"><%= session[:admin_uid] %></span>
    </p>

    <div class="flex items-center justify-center gap-3 pt-2">
      <%= link_to "管理者を追加", new_admin_admin_path,
                  class: "inline-flex items-center justify-center rounded-md bg-green-600 px-4 py-2 font-bold text-white shadow hover:bg-green-700 transition" %>

      <%= link_to "管理者トップへ", admin_root_path,
                  class: "inline-flex items-center justify-center rounded-md bg-white px-4 py-2 font-bold text-green-700 border border-green-200 hover:bg-green-50 transition" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-orange-100 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-orange-50">
        <tr>
          <th class="text-left px-4 py-3">名前</th>
          <th class="text-left px-4 py-3">UID</th>
          <th class="text-left px-4 py-3">追加日</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>

      <tbody class="divide-y">
        <% @admins.each do |admin| %>
          <tr class="hover:bg-orange-50/40">
            <td class="px-4 py-3 text-gray-800">
              <span class="font-bold">
                <%= admin.user&.name.presence || "（未ログイン）" %>
              </span>

              <% if admin.uid == session[:admin_uid] %>
                <span class="ml-2 inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                  あなた
                </span>
              <% end %>
            </td>

            <td class="px-4 py-3 font-mono text-xs text-gray-700 break-all">
              <%= admin.uid %>
            </td>

            <td class="px-4 py-3 text-gray-600">
              <%= l(admin.created_at, format: :short) rescue admin.created_at %>
            </td>

            <td class="px-4 py-3 text-right">
              <%= button_to "削除",
                            admin_admin_path(admin),
                            method: :delete,
                            data: { turbo_confirm: "この管理者を削除しますか？" },
                            class: "inline-flex items-center justify-center rounded-md bg-white px-3 py-1.5 font-bold text-red-600 border border-red-200 hover:bg-red-50 transition" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>