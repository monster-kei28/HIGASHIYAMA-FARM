<div class="max-w-3xl mx-auto px-4 py-10 space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold">カレンダー設定（<%= @month.strftime("%Y年%-m月") %>）</h1>

    <div class="flex gap-2">
      <%= link_to "← 前月", admin_calendar_events_path(month: @month.prev_month.strftime("%Y-%m-01")),
            class: "text-sm underline text-gray-700" %>
      <%= link_to "次月 →", admin_calendar_events_path(month: @month.next_month.strftime("%Y-%m-01")),
            class: "text-sm underline text-gray-700" %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-md border border-orange-100">
    <%= form_with url: bulk_update_admin_calendar_events_path, method: :post, local: true, data: { controller: "calendar-bulk" } do %>
      <div class="mb-4 flex flex-wrap gap-2">
        <button type="button"
                data-action="calendar-bulk#allOpen"
                class="rounded bg-green-600 text-white px-3 py-2 text-sm">
          全日：開催
        </button>

        <button type="button"
                data-action="calendar-bulk#allClosed"
                class="rounded bg-red-600 text-white px-3 py-2 text-sm">
          全日：休み
        </button>

        <button type="button"
                data-action="calendar-bulk#weekdaysClosedWeekendsOpen"
                class="rounded bg-blue-600 text-white px-3 py-2 text-sm">
          平日：休み
        </button>

        <button type="button"
                data-action="calendar-bulk#weekendsClosed"
                class="rounded bg-orange-500 text-white px-3 py-2 text-sm">
          土日：休み
        </button>

        <button type="button"
                data-action="calendar-bulk#clear"
                class="rounded bg-gray-200 text-gray-800 px-3 py-2 text-sm">
          全クリア
        </button>
      </div>
      <%= hidden_field_tag :month, @month.strftime("%Y-%m-01") %>

      <div class="mx-auto w-full max-w-2xl">
        <%= month_calendar start_date: @start_date, start_date_param: :month do |date| %>
          <% in_month = (date.month == @month.month) %>

          <div class="flex flex-col h-full <%= in_month ? '' : 'opacity-40' %>">
            <span class="text-sm font-bold text-orange-700"><%= date.day %></span>

            <% current = @events_by_date[date]&.kind %>

            <%= select_tag "events[#{date.strftime('%Y-%m-%d')}]",
                  options_for_select([["未設定",""], ["開催","open"], ["休み","closed"]], current),
                  class: "mt-2 rounded border px-1 py-1 text-xs",
                  disabled: !in_month,
                  data: { calendar_bulk_target: "select", date: date.strftime("%Y-%m-%d") } %>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex justify-center gap-3">
        <%= submit_tag "この月を保存", class: "rounded bg-green-600 text-white px-5 py-2" %>
        <%= link_to "管理者トップへ", admin_root_path, class: "rounded bg-gray-100 px-5 py-2" %>
      </div>
    <% end %>
  </div>
</div>