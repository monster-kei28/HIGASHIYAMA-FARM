<div class="max-w-5xl mx-auto px-4 py-10 space-y-6">
  <div class="bg-white rounded-lg shadow-md border border-orange-100 p-6 space-y-3">
    <div class="text-center space-y-1">
      <h1 class="text-xl font-bold text-green-700">LINEログイン済みユーザー</h1>
      <p class="text-sm text-gray-600">
        ここから管理者に追加できます
      </p>
    </div>

    <div class="flex items-center justify-center gap-3 pt-2">
      <%= link_to "管理者一覧へ", admin_admins_path,
          class: "inline-flex items-center justify-center rounded-md bg-white px-4 py-2 font-bold text-green-700 border border-green-200 hover:bg-green-50 transition" %>

      <%= link_to "管理者トップへ", admin_root_path,
          class: "inline-flex items-center justify-center rounded-md bg-gray-100 px-4 py-2 font-bold text-gray-700 hover:bg-gray-200 transition" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-orange-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-[900px] w-full text-sm">
        <thead class="bg-orange-50">
          <tr>
            <th class="text-left px-4 py-3">名前</th>
            <th class="text-left px-4 py-3">電話</th>
            <th class="text-left px-4 py-3">登録日</th>
            <th class="px-4 py-3 text-right">操作</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% @users.each do |user| %>
            <% is_admin = @admin_user_ids.include?(user.id) %>

            <tr class="hover:bg-orange-50/40">
              <td class="px-4 py-3 font-bold text-gray-800 whitespace-nowrap">
                <%= user.name.presence || "（未入力）" %>
                <% if is_admin %>
                  <span class="ml-2 inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                    管理者
                  </span>
                <% end %>
              </td>

              <td class="px-4 py-3 text-gray-700 whitespace-nowrap">
                <%= user.phone_number.presence || "—" %>
              </td>

              <td class="px-4 py-3 text-gray-600 whitespace-nowrap">
                <%= l(user.created_at, format: :short) rescue user.created_at %>
              </td>

              <td class="px-4 py-3 text-right whitespace-nowrap">
                <% if is_admin %>
                  <span class="inline-flex items-center justify-center rounded-md bg-gray-100 px-3 py-1.5 text-xs font-bold text-gray-500 border border-gray-200">
                    追加済み
                  </span>
                <% else %>
                  <%= button_to "管理者にする",
                        admin_admins_path(admin: { uid: user.uid }),
                        method: :post,
                        form: { data: { turbo_confirm: "このユーザーを管理者に追加しますか？" } },
                        class: "inline-flex items-center justify-center rounded-md bg-green-600 px-3 py-1.5 text-xs font-bold text-white shadow hover:bg-green-700 transition" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @users.empty? %>
      <div class="text-center text-sm text-gray-600 py-8">
        LINEログイン済みユーザーはまだいません。
      </div>
    <% end %>
  </div>
</div>