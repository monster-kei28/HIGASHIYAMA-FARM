<section class="bg-white p-6 rounded-lg shadow-md border border-orange-100 space-y-3">
  <% if title.present? %>
    <h3 class="text-lg font-bold text-center"><%= title %></h3>
  <% end %>

  <div class="mx-auto w-full max-w-md">
    <%= month_calendar events: events do |date, day_events| %>
      <% reservable = !CalendarEvent.closed_on?(date) &&
                      date >= min_reservable_date &&
                      date <= max_reservable_date %>

      <div class="flex flex-col h-full">
        <% if reservable %>
          <%= link_to new_reservation_path(date: date , anchor: "reservation-form"),
              class: "block text-sm font-bold text-orange-700 hover:underline" do %>
            <%= date.day %>
          <% end %>
        <% else %>
          <span class="block text-sm font-bold text-gray-400">
            <%= date.day %>
          </span>
        <% end %>

        <% day_events.each do |event| %>
          <span class="mt-1 rounded px-1 text-xs <%= event.closed? ? 'bg-gray-200 text-gray-600' : 'bg-orange-200 text-gray-800' %>">
            <%= event.title %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if note.present? %>
    <p class="text-center text-sm text-gray-600"><%= note %></p>
  <% end %>
</section>