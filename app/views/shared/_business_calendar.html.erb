<section class="bg-white p-6 rounded-lg shadow-md border border-orange-100 space-y-3">
  <% if title.present? %>
    <h3 class="text-lg font-bold text-center"><%= title %></h3>
  <% end %>

  <%= month_calendar events: events do |date, day_events| %>
    <% closed = closed_dates.include?(date) %>
    <% reservable = !closed && date >= min_reservable_date && date <= max_reservable_date %>

    <div class="flex flex-col h-full gap-1">

      <% if reservable %>
        <%= link_to new_reservation_path(date: date, anchor: "reservation-form"),
            class: "inline-flex items-center justify-center w-6 h-6 rounded-full bg-orange-400 text-white text-sm font-bold hover:bg-orange-500 transition" do %>
          <%= date.day %>
        <% end %>
      <% elsif closed %>
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full border border-gray-300 text-gray-400 text-sm font-bold">
          <%= date.day %>
        </span>
      <% else %>
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-gray-400 text-sm">
          <%= date.day %>
        </span>
      <% end %>

      <% day_events.each do |event| %>
        <span class="mt-1 rounded px-1 text-xs <%= event.closed? ? 'bg-gray-200 text-gray-600' : 'bg-orange-200 text-gray-800' %>">
          <%= event.title %>
        </span>
      <% end %>
    </div>
  <% end %>

  <% if note.present? %>
    <p class="text-center text-sm text-gray-600"><%= note %></p>
  <% end %>
</section>