    <%= link_to root_path, class: "flex items-center gap-2 text-xl font-extrabold tracking-wide hover:opacity-90 transition" do %>
      <span>🥕</span>
      <span>HIGASHIYAMA FARM</span>
    <% end %>

    <nav class="flex flex-wrap justify-center gap-6 text-sm font-medium">
