<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "HIGASHIYAMA FARM" %></title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# OGP（LINE用に最優先で揃える） %>
    <meta property="og:title" content="<%= content_for(:title) || "HIGASHIYAMA FARM｜さつまいも収穫体験予約" %>">
    <meta property="og:description" content="千葉県柏市の農園でさつまいも収穫体験。家族で楽しめる収穫体験を開催しています。">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= image_url('HIGASHIYAMA_FARM.png') %>">
    <meta property="og:site_name" content="HIGASHIYAMA FARM">

    <%# Twitter %>
    <meta name="twitter:card" content="summary_large_image">

    <%= yield :head %>

    <!-- link rel="manifest" href="/manifest.json" -->
    <link rel="icon" type="image/png" sizes="32x32" href="<%= asset_path('favicon-32x32.png') %>">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= asset_path('favicon-16x16.png') %>">
    <link rel="apple-touch-icon" sizes="180x180" href="<%= asset_path('apple-touch-icon.png') %>">
    <link rel="icon" href="<%= asset_path('favicon.ico') %>">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= render 'shared/header' %>

    <% if notice %>
      <p class="bg-green-100 text-green-800 px-4 py-2 mb-4 text-center">
        <%= notice %>
      </p>
    <% end %>

    <% if alert %>
      <p class="bg-red-100 text-red-800 px-4 py-2 mb-4 text-center">
        <%= alert %>
      </p>
    <% end %>

    <%= yield %>

  <%= render 'shared/footer' %>
  </body>
</html>
