<div class="max-w-2xl mx-auto px-4 py-10 space-y-10">

  <% if @reservation&.errors&.any? %>
    <div class="p-4 bg-red-100 border border-red-400 rounded text-red-700">
      <h3 class="font-bold">入力内容にエラーがあります</h3>
      <ul class="list-disc ml-5">
        <% @reservation.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h2 class="text-center">
    <span class="inline-block bg-orange-100 px-6 py-2 text-xl font-bold">
      予約フォーム
    </span>
  </h2>

  <!-- カレンダー -->
  <%= render "shared/business_calendar",
    events: @events,
    title: "営業日カレンダー",
    note: "※営業時間は10:00〜16:00です" %>

  <!-- LINEログイン -->
  <section class="bg-white p-6 rounded-lg shadow-md border border-orange-100 space-y-3">
    <h3 class="text-lg font-bold text-green-700 text-center">LINEログイン（任意）</h3>

    <% if logged_in? %>
      <div class="p-4 bg-green-50 border border-green-200 rounded text-center">
        <p class="font-bold text-green-800">✅ LINEでログイン済みです</p>
        <p class="text-sm text-green-700 mt-1">予約完了通知を受け取れます</p>
      </div>
    <% else %>
      <div class="max-w-md mx-auto space-y-2">
        <%= button_to "LINEでログインして予約する（任意）",
                      "/auth/line",
                      method: :post,
                      data: { turbo: false },
                      class: "w-full text-center rounded bg-green-600 px-4 py-3 font-bold text-white hover:bg-green-700" %>

        <p class="text-sm text-gray-600 text-center">
          ※予約完了通知を受けたい方はLINEでログインしてください
        </p>

        <p class="text-xs text-gray-500 text-center">
          ※ログインしなくても予約できます
        </p>
      </div>
    <% end %>
  </section>

  <!-- 入力フォーム -->
  <section class="bg-white p-6 rounded-lg shadow-md border border-orange-100">
    <%= form_with model: @reservation, local: true, class: "space-y-5" do |f| %>

      <div>
        <%= f.label :name, "名前", class: "block text-gray-700 font-medium mb-2" %>

        <%= f.text_field :name,
            class: "w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-300" %>

        <p class="mt-2 text-sm text-gray-500">
          ※受付時に確認しますので、本名でご入力ください
        </p>
      </div>

      <div>
        <%= f.label :phone_number, "電話番号", class: "block text-gray-700 font-medium mb-2" %>

        <%= f.telephone_field :phone_number,
            placeholder: "09012345678",
            class: "w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-300" %>

        <div class="mt-2 space-y-1 text-sm text-gray-500">
          <p>※ハイフンなしで入力してください（例：09012345678）</p>
        </div>
      </div>

      <div>
        <%= f.label :harvest_experience_id, "収穫体験を選択", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.collection_select :harvest_experience_id,
            @harvest_experiences,
            :id, :title,
            { prompt: "選択してください" },
            { class: "w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-300" } %>
      </div>

      <div>
        <%= f.label :number_of_people, "人数", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.number_field :number_of_people, class: "w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-300" %>
      </div>

      <div>
        <%= f.label :reserved_at, "希望日時", class: "block text-gray-700 font-medium mb-2" %>

        <%= f.datetime_local_field :reserved_at,
            class: "w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-300" %>

        <div class="mt-2 space-y-1 text-sm text-gray-500">
          <p>例：2026-02-15 10:00</p>
          <p>※受付時間は10:00〜16:00です</p>
          <p>※営業日カレンダーを参考に日時を選んでください</p>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "予約する",
            class: "w-full sm:max-w-sm sm:mx-auto block text-center rounded bg-orange-500 px-4 py-3 font-bold text-white hover:bg-orange-600" %>
      </div>

    <% end %>
  </section>

</div>
